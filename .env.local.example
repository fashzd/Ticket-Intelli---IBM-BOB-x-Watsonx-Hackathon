# WatsonX.ai Configuration
# Copy this file to .env.local and fill in your actual values

# IBM Cloud API Key
# Get this from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# WatsonX Project ID
# Get this from your watsonx.ai project settings
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# WatsonX Service URL (optional, defaults to us-south)
# Options: 
# - https://us-south.ml.cloud.ibm.com (US South)
# - https://eu-de.ml.cloud.ibm.com (Frankfurt)
# - https://eu-gb.ml.cloud.ibm.com (London)
# - https://jp-tok.ml.cloud.ibm.com (Tokyo)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# WatsonX Model ID (optional, defaults to granite-3-8b-instruct)
# Recommended: ibm/granite-3-8b-instruct
# Other options: ibm/granite-13b-instruct-v2, meta-llama/llama-3-70b-instruct
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Setup Instructions:
# 1. Sign up for IBM Cloud: https://cloud.ibm.com/registration
# 2. Create a watsonx.ai project: https://dataplatform.cloud.ibm.com/wx/home
# 3. Generate an API key from IBM Cloud IAM
# 4. Copy your project ID from the watsonx.ai project settings
# 5. Copy this file to .env.local and fill in your credentials
# 6. Restart your development server

# Note: Without these credentials, the application will fall back to mock analysis